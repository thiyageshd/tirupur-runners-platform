# Copy this to .env and fill in values
APP_NAME=Tirupur Runners Club
DEBUG=True

# PostgreSQL — get from Neon.tech or Supabase
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/tirupur_runners

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Razorpay — from dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Membership fee in paise (50000 = ₹500)
MEMBERSHIP_AMOUNT_PAISE=50000

# Admin default email
ADMIN_EMAIL=admin@tirupurrunners.com

# SendGrid (optional — leave blank for console logging in dev)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@tirupurrunners.com

# Frontend URL for CORS
FRONTEND_URL=https://tirupurrunners.com
